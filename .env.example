# 7greens — Vercel environment variables
#
# All env vars are OPTIONAL. The site renders fully without any of them
# (using static fallbacks from lib/site/constants.ts). Add these as
# Vercel project env vars when you're ready to wire live commerce.

# ─────────────────────────────────────────────────────────────────
# Square — commerce (Phase 04 wires Orders + Payments; for v1 only
# Customers API is needed for lead capture)
# ─────────────────────────────────────────────────────────────────

# Square access token (sandbox in preview, production in production)
# Get one at https://developer.squareup.com/apps
# When unset: lead-capture form returns success without persisting; box
# pricing/items render from BOX_FALLBACKS in lib/site/constants.ts.
SQUARE_ACCESS_TOKEN=

# Square location ID for this merchant
SQUARE_LOCATION_ID=

# "sandbox" or "production"
SQUARE_ENVIRONMENT=sandbox

# Webhook signing key (Phase 04+)
SQUARE_WEBHOOK_SIGNATURE_KEY=

# ─────────────────────────────────────────────────────────────────
# Email (Phase 05 — newsletter / order confirmation; optional)
# ─────────────────────────────────────────────────────────────────

# RESEND_API_KEY=
# RESEND_FROM=

# ─────────────────────────────────────────────────────────────────
# Anti-bot (recommended on Vercel)
# ─────────────────────────────────────────────────────────────────

# Vercel BotID requires no env var — enable it in the Vercel dashboard.
