# =============================================================================
# UPAEC — environment variables reference
#
# Copy this file to .env.local and fill in your values.
# Keys marked REQUIRED must be set before the feature works.
# Keys marked OPTIONAL degrade gracefully when unset (sandbox defaults, etc.).
#
# Live values should be set as Vercel project environment variables so
# `gad env doctor --projectid upaec` and the desk Env route can validate them.
# =============================================================================

# =============================================================================
# Square — Primary commerce layer (catalog, payments, subscriptions)
# Feature: square_commerce
# Dashboard: https://developer.squareup.com/apps
# =============================================================================

# REQUIRED — Square OAuth access token.
# Use the sandbox token for dev/preview, production token for live payments.
# Get it from: Developer Dashboard → Applications → OAuth → Access Token
SQUARE_ACCESS_TOKEN=EAAAl_placeholder_replace_with_real_token

# OPTIONAL — Square API environment. Default: sandbox
# Values: sandbox | production
SQUARE_ENVIRONMENT=sandbox

# OPTIONAL — Square merchant location ID.
# Scopes catalog queries and payment processing to a specific location.
# Find it: Developer Dashboard → Locations
SQUARE_LOCATION_ID=

# OPTIONAL — Square webhook signature key (phase 272 webhooks).
# Used to validate incoming webhook payloads in app/api/webhooks/square/route.ts
SQUARE_WEBHOOK_SIGNATURE_KEY=

# REQUIRED for checkout — Square application ID. Safe to expose in client bundles.
# Get it from: Developer Dashboard → Applications → Application ID
# Sandbox example: sandbox-sq0idb-placeholder
NEXT_PUBLIC_SQUARE_APPLICATION_ID=sandbox-sq0idb-placeholder

# REQUIRED for checkout — Square location ID exposed to the client.
# Must match SQUARE_LOCATION_ID. Find it: Developer Dashboard → Locations
NEXT_PUBLIC_SQUARE_LOCATION_ID=

# OPTIONAL — Square environment for the Web Payments SDK (sandbox | production).
# Defaults to sandbox. Controls which Square CDN script URL loads in the browser.
NEXT_PUBLIC_SQUARE_ENVIRONMENT=sandbox

# =============================================================================
# Supabase — Data layer (delivery zones, order metadata, ZIP routing)
# Feature: supabase_data
# Dashboard: https://supabase.com/dashboard/project/_/settings/api
# Phase: 272-07
# =============================================================================

# REQUIRED — Supabase project URL. Safe to expose in client bundles.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# REQUIRED — Supabase anon (publishable) key. RLS-enforced.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_placeholder

# SERVER ONLY — Supabase service role key. Bypasses ALL RLS.
# Never prefix with NEXT_PUBLIC_. Used by server-side admin routes only.
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# Resend — Transactional email (order confirmation, delivery reminders)
# Feature: resend_email
# Dashboard: https://resend.com/api-keys
# Phase: 272-09 / 10-03
# =============================================================================

# REQUIRED — Resend API key for sending transactional emails.
RESEND_API_KEY=re_placeholder

# OPTIONAL — From address for outgoing emails. Must be a verified Resend sender.
RESEND_FROM=orders@upaec.com

# =============================================================================
# Clerk — Auth / user identity (UPAEC tenant, D-425)
# Feature: clerk_auth
# Dashboard: https://dashboard.clerk.com/apps
# Phase: 272-06
# =============================================================================

# REQUIRED — Clerk publishable key. Safe to embed in client bundles.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_placeholder

# REQUIRED — Clerk secret key. Server-only — never expose in client code.
CLERK_SECRET_KEY=sk_test_placeholder

# OPTIONAL — Custom sign-in/sign-up page paths (defaults to Clerk-hosted UI).
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# =============================================================================
# Twilio — SMS notifications (day-before delivery reminders)
# Feature: twilio_sms (optional — email notifications via Resend are primary)
# Dashboard: https://console.twilio.com
# Phase: 272-09
# =============================================================================

# OPTIONAL — Twilio account SID. Required only when SMS notifications are enabled.
# TWILIO_ACCOUNT_SID=ACplaceholder

# OPTIONAL — Twilio auth token. Server-only.
# TWILIO_AUTH_TOKEN=

# OPTIONAL — E.164 formatted Twilio phone number to send SMS from.
# TWILIO_FROM_NUMBER=+15551234567
